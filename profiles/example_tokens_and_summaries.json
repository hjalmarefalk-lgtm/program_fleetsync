{
  "job_id": "example_tokens_and_summaries",
  "export_label": "example",
  "workbooks": [
    {
      "workbook_id": "wb_1",
      "referenced_sheet": "Sheet1",
      "workbook_name_template": "{YYYY_MM_DD}",
      "split": {"split_col": "", "selected_values": []},
      "column_policy": {"keep_cols": [], "drop_cols": [], "order_cols": []},
      "drop_rows": [],
      "row_order": {"sort_keys": ["Group"], "ascending": true},
      "tokens": [
        {
          "token_id": "info_presence",
