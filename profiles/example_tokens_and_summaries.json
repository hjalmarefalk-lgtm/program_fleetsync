          "inputs": {"source_col": "Info", "values": ["VALUE_A", "VALUE_B"], "separator": ","},
          "scope": "workbook"
        }
      ],
      "summaries": [
        {
          "summary_id": "s_group_metrics",
          "summary_type": "group_aggregate",
          "scope": "workbook",
          "group_by": "Group",
          "metrics": [
            {"op": "count_rows"},
            {"op": "sum", "col": "Value"},
            {"op": "avg", "col": "Value"},
            {"op": "distinct_count", "col": "Value"},
            {"op": "null_rate", "col": "Info"}
          ]
        }
      ]
    }
  ]
